    </tgroup>
   </informaltable>
  </para>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <para>
   <example>
    <title><function>preg_replace_callback_array</function> 示例</title>
    <programlisting role="php">
<![CDATA[
<?php
$subject = 'Aaaaaa Bbb';

preg_replace_callback_array(
    [
        '~[a]+~i' => function ($match) {
            echo strlen($match[0]), ' matches for "a" found', PHP_EOL;
        },
        '~[b]+~i' => function ($match) {
            echo strlen($match[0]), ' matches for "b" found', PHP_EOL;
        }
    ],
    $subject
);
?>
]]>
    </programlisting>
    &example.outputs;
    <screen>
<![CDATA[
6 matches for "a" found
3 matches for "b" found
]]>
    </screen>
   </example>
  </para>
 </refsect1>

