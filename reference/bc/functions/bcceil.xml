<refentry xml:id="function.bcceil" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>bcceil</refname>
  <refpurpose>向上舍入任意精度数字</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>string</type><methodname>bcceil</methodname>
   <methodparam><type>string</type><parameter>num</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   通过向上舍入返回下一个最高整数值（如有必要）。
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>num</parameter></term>
    <listitem>
     <simpara>
      要舍入的值。
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   返回一个数值字符串，表示 <parameter>num</parameter> 向上舍入到最接近的整数。
  </simpara>
 </refsect1>

 <refsect1 role="errors">
  &reftitle.errors;
  <simpara>
   如果 <parameter>num</parameter> 不是格式良好的 BCMath 数值字符串，此函数会抛出 <exceptionname>ValueError</exceptionname> 异常。
  </simpara>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example>
   <title><function>bcceil</function> 示例</title>
   <programlisting role="php">
<![CDATA[
<?php
var_dump(bcceil('4.3'));
var_dump(bcceil('9.999'));
var_dump(bcceil('-3.14'));
?>
]]>
   </programlisting>
   &example.outputs;
   <screen role="php">
<![CDATA[
string(1) "5"
string(2) "10"
string(2) "-3"
]]>
   </screen>
  </example>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>bcfloor</function></member>
   <member><function>bcround</function></member>
   <member><methodname>BcMath\Number::ceil</methodname></member>
  </simplelist>
 </refsect1>
</refentry>
